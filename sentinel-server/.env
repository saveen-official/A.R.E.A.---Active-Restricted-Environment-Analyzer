# ── Server & Wi-Fi Connection ─────────────────────────────────
PORT=3000
TCP_PORT=8080

# ── Alert Settings ────────────────────────────────────────────
# RF threshold in dBm — signals above this value trigger a phone alert
RF_THRESHOLD=1.5

# Sound threshold (now using true decibel math from ESP32)
SOUND_THRESHOLD=70

# Room identifier shown in SMS, Telegram, and dashboard
ROOM_NAME=Exam Hall Room 01

# ── SMS (via SIM900A on ESP32) ────────────────────────────────
# The server sends the SMS command to the ESP32 over Wi-Fi, 
# which then texts this number.
INVIGILATOR_PHONE=+94764574244

# ── Telegram Alert Credentials ────────────────────────────────
# Get the Token from @BotFather and Chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=7948765017:AAFQoTO0b41rLWDSxXYxSe7JThiTrAjcXJY
TELEGRAM_CHAT_ID=5772858233